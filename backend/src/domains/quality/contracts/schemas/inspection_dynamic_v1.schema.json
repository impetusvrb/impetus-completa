{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://impetus.local/schemas/quality/inspection_dynamic_v1",
  "title": "Inspeção dinâmica universal",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "inspection_id": { "type": "string", "minLength": 1 },
    "line_id": { "type": "string" },
    "batch_id": { "type": "string" },
    "characteristics": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "datatype": { "enum": ["numeric", "text", "boolean", "enum", "media", "micro"] },
          "nominal": { "type": "number" },
          "lsl": { "type": "number" },
          "usl": { "type": "number" },
          "unit": { "type": "string" },
          "enum_options": { "type": "array", "items": { "type": "string" } },
          "required": { "type": "boolean" }
        },
        "required": ["code", "datatype"]
      }
    },
    "attachments": {
      "type": "array",
      "items": { "type": "object", "properties": { "uri": { "type": "string" } } }
    }
  },
  "required": ["inspection_id", "characteristics"]
}
