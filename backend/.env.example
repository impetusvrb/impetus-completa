# =============================================================================
# IMPETUS BACKEND (raiz) — exemplo de variáveis de ambiente
# Copie para .env e preencha. Não commite o ficheiro .env com segredos.
# Unificado com impetus_complete/backend: D-ID, OpenAI Realtime, Google TTS, sockets.
# =============================================================================

NODE_ENV=development
PORT=4000
# Nunca em produção: permite arranque com env incompleto (aviso no log). Ver configValidator.js
ALLOW_PARTIAL_ENV=false

# -----------------------------------------------------------------------------
# Base de dados PostgreSQL
# -----------------------------------------------------------------------------
# Obrigatório em produção: defina DATABASE_URL (recomendado) **ou** DB_HOST + DB_NAME + DB_USER.
# (arranque: src/config/configValidator.js — com ALLOW_PARTIAL_ENV pode ignorar em dev local.)
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=impetus_db
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECT_TIMEOUT=10000

# -----------------------------------------------------------------------------
# JWT e URLs
# -----------------------------------------------------------------------------
JWT_SECRET=
# Impetus Admin / painel master (tokens admin)
IMPETUS_ADMIN_JWT_SECRET=
FRONTEND_URL=
BASE_URL=

# Health check: GET /health e /api/health — detalhes (ex. TTS) só com este segredo no cabeçalho X-Health-Key ou pedido local (127.0.0.1).
HEALTH_DETAIL_KEY=

# -----------------------------------------------------------------------------
# OpenAI (chat, embeddings, Whisper, TTS, Realtime)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_TTS_DEFAULT_SPEED=0.98
OPENAI_TTS_INSTRUCTIONS=
FORCE_TTS_VOICE=
# Humanização OpenAI TTS (opcional)
OPENAI_TTS_HUMANIZE_STRENGTH=0.65
OPENAI_TTS_WARMTH=0.52
OPENAI_TTS_INTONATION=0.72
OPENAI_TTS_KEYWORD_EMPHASIS=0.72
OPENAI_TTS_SYLLABIC_VARIATION=0.68
OPENAI_TTS_FINAL_FALL=0.74

# Motor TTS: openai | google (via voiceTtsService)
IMPETUS_TTS_PROVIDER=
TTS_ENGINE=
GOOGLE_TTS_ENABLED=

# -----------------------------------------------------------------------------
# OpenAI Realtime (WebSocket proxy no servidor — voz contínua)
# -----------------------------------------------------------------------------
IMPETUS_REALTIME_PROXY_ENABLED=false
IMPETUS_REALTIME_WS_PATH=/impetus-realtime
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# Cabeçalho beta da API OpenAI Realtime (opcional; deixe vazio na maioria dos casos)
OPENAI_REALTIME_BETA=

# -----------------------------------------------------------------------------
# Lipsync Wav2Lip (áudio Realtime → serviço externo)
# -----------------------------------------------------------------------------
IMPETUS_REALTIME_LIPSYNC_ENABLED=false
IMPETUS_LIPSYNC_URL=http://127.0.0.1:5001/lipsync
IMPETUS_LIPSYNC_FACE_VIDEO=
IMPETUS_REALTIME_OUTPUT_AUDIO_HZ=24000
IMPETUS_LIPSYNC_MIN_PCM_BYTES=24000

# -----------------------------------------------------------------------------
# D-ID (avatar talking-head — usado quando rota /api/did estiver montada)
# -----------------------------------------------------------------------------
D_ID_API_KEY=
D_ID_API_BASE=https://api.d-id.com
# URL HTTPS pública da imagem do rosto (teste: scripts/test-did.js)
D_ID_SOURCE_URL=
# No frontend, VITE_DID_SOURCE_URL / VITE_DID_AVATAR_ENABLED alinham com este módulo

# -----------------------------------------------------------------------------
# Socket.IO — namespaces usados no legado impetus_complete (config no código)
# -----------------------------------------------------------------------------
# Chat: /socket.io | Avatar lipsync: /impetus-avatar | TTS stream: /impetus-voice
# CORS e path são definidos em server.js; não há variáveis obrigatórias adicionais hoje.

# -----------------------------------------------------------------------------
# Google Cloud Text-to-Speech
# -----------------------------------------------------------------------------
# Caminho para JSON de service account OU use GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_TTS_KEYFILE=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_LANG=pt-BR
GOOGLE_TTS_VOICE=
GOOGLE_TTS_ENABLED=
GOOGLE_TTS_DEFAULT_SPEAKING_RATE=0.95
GOOGLE_TTS_PITCH=-0.5
GOOGLE_TTS_VOLUME_GAIN_DB=1.5
GOOGLE_TTS_USE_SSML=
GOOGLE_TTS_TEMPLATE_NAME=
GOOGLE_TTS_WELCOME_SPELL_NAME=
# SSML fino (ver googleTtsCore / voiceTtsService)
# Pitch SSML em semitons (opcional; senão usa GOOGLE_TTS_PITCH)
GOOGLE_TTS_SSML_PITCH_ST=
GOOGLE_TTS_SSML_BASE_PITCH_PCT=-1
GOOGLE_TTS_SSML_BASE_RATE_PCT=98
GOOGLE_TTS_SSML_FALL_PITCH_PCT=-2
GOOGLE_TTS_SSML_FALL_RATE_PCT=93
GOOGLE_TTS_SSML_EMPHASIS=moderate
GOOGLE_TTS_SSML_SENTENCE_FALL=
GOOGLE_TTS_SSML_BREATH=
GOOGLE_TTS_SSML_BREATH_MAX=2
GOOGLE_TTS_SSML_OUTER_MODE=pct
GOOGLE_TTS_SSML_NEURAL_OUTER=
GOOGLE_TTS_SSML_NEURAL_OUTER_PITCH_ST=-8
GOOGLE_TTS_SSML_NEURAL_OUTER_RATE_PCT=-17
GOOGLE_TTS_SSML_NEURAL_OUTER_VOLUME=
GOOGLE_TTS_SSML_CHUNK_CLOSURE_MS=
GOOGLE_TTS_SSML_RHYTHM_ALT=
GOOGLE_TTS_SSML_RHYTHM_ALT_RATE_PCT=+6
GOOGLE_TTS_SSML_FINAL_SLOW=
GOOGLE_TTS_SSML_FINAL_SLOW_RATE_PCT=-5
GOOGLE_TTS_BREAK_MS=
GOOGLE_TTS_SENTENCE_BREAK_MS=
GOOGLE_TTS_INTENT_PREFIX=

# -----------------------------------------------------------------------------
# Outras IAs
# -----------------------------------------------------------------------------
# Anthropic: obrigatório para POST /api/vision (ManuIA 3D — Claude multimodal).
# O browser chama /api/vision com o mesmo Bearer do login (impetus_token).
ANTHROPIC_API_KEY=
# Painel de comando visual (voz): interpretação do pedido — claude se ANTHROPIC_API_KEY existir; openai para forçar GPT.
# SMART_PANEL_AI_PROVIDER=openai|claude|anthropic
# SMART_PANEL_CLAUDE_MODEL=claude-sonnet-4-20250514
# Modelo dedicado ao painel pós-voz (opcional; senão usa SMART_PANEL_CLAUDE_MODEL)
# CLAUDE_PANEL_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Gemini via Vertex AI (opcional)
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=false

# ffmpeg: análise de campo (technical library) extrai frames de vídeo via execFile seguro.
# Recomendado em produção: caminho absoluto ao binário (allowlist no código). Ex.: /usr/bin/ffmpeg
# FFMPEG_PATH=

# -----------------------------------------------------------------------------
# Asaas (assinaturas e webhooks)
# -----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=

# -----------------------------------------------------------------------------
# SMTP / e-mail
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_PASSWORD=
SMTP_FROM=

# URL da app cliente IMPETUS (prioridade sobre FRONTEND_URL nos links de convite/reset). Não use a porta do painel admin (5174).
# Local: alinhar com frontend — PM2 `preview:prod` / serveDist usa 3000 por defeito; `vite` dev usa PORT ou VITE_DEV_PORT (padrão 3000 neste repo).
IMPETUS_CLIENT_APP_URL=

# Painel master (impetus-admin): se o convite não for enviado por falta de SMTP,
# em NODE_ENV !== production a API pode devolver debug_activation_url (valor exatamente "true").
# Com NODE_ENV=production o link NUNCA é devolvido; se esta flag estiver true, regista-se apenas [SECURITY_OVERRIDE] nos logs (sem URL).
ADMIN_PORTAL_DEBUG_INVITE_LINK=false

# -----------------------------------------------------------------------------
# Webhooks de mensagens recebidas (POST /api/webhook — WhatsApp, etc.)
# O cliente deve enviar o mesmo segredo em X-Webhook-Secret ou Authorization: Bearer <segredo>
# Meta / WhatsApp Cloud: opcionalmente defina o App Secret e valide X-Hub-Signature-256 (corpo bruto).
# -----------------------------------------------------------------------------
INCOMING_WEBHOOK_SECRET=
META_APP_SECRET=
# Alternativas ao App Secret Meta (usa o primeiro definido):
WHATSAPP_APP_SECRET=
FACEBOOK_APP_SECRET=

# Governança de incidentes de IA: POST JSON em incidente CRITICAL (type AI_CRITICAL_INCIDENT, ver governanceAlertService)
GOVERNANCE_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Segurança, limites, feature flags
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
SALT=
RATE_LIMIT_API_PER_MIN=120
RATE_LIMIT_USER_PER_MIN=300
RATE_LIMIT_HEAVY_PER_MIN=30
RATE_LIMIT_APP_IMPETUS_PER_SEC=2
PAGINATION_COUNT_CAP=10001
APP_COMM_MAX_FILE_MB=25
CACHE_MAX_ENTRIES=1000
HTTP_TIMEOUT_MS=15000
HTTP_RETRIES=3
LOG_FORMAT=
DEBUG=

FEATURE_AI_CHAT=
FEATURE_OPERATIONAL_BRAIN=
FEATURE_INDUSTRIAL=
FEATURE_ROLE_VERIFICATION=
# Orquestrador multi-modelo no chat/dashboard (legado impetus_complete — chatAIService, rotas dashboard)
AI_ORCHESTRATOR_ENABLED=

# Motor unificado — auditoria de decisões (memória por processo) e snapshot de saúde nos logs
# GET /api/internal/unified-health (requireAuth + internal_admin). Sem efeitos externos.
UNIFIED_DECISION_AUDIT=false
UNIFIED_SYSTEM_HEALTH=false
# Validação de qualidade de decisão (só observabilidade — logs + buffer; não altera decisões)
UNIFIED_DECISION_VALIDATION=false
UNIFIED_VALIDATION_BUFFER=500
# Autonomia supervisionada (notificações/tarefas seguras via operationalActionExecutor; rollback após janela). false = sem execução automática.
UNIFIED_AUTONOMY_ENABLED=false
# Janela (ms) antes de avaliar rollback (learning bad/fallback ou heurística de alertas alta).
UNIFIED_AUTONOMY_ROLLBACK_MS=30000
# Se true, exige requires_attention===false e priority_override===false em system_influence (bloca quase sempre com o modelo atual).
UNIFIED_AUTONOMY_STRICT_INFLUENCE=false
UNIFIED_AUDIT_BUFFER_SIZE=500
# Alertas internos (apenas console.warn) quando fallback/latência/estabilidade degradam. Antispam por empresa e tipo.
# UNIFIED_HEALTH_ALERTS=false desliga. Omisso: ativo.
UNIFIED_HEALTH_ALERTS=
UNIFIED_HEALTH_ALERT_LATENCY_MS=
UNIFIED_HEALTH_ALERT_COOLDOWN_MS=
# Performance observability (motor unificado) — buffer em memória; UNIFIED_PERF_RECORDING=false desliga.
UNIFIED_PERF_RECORDING=
UNIFIED_PERF_BUFFER_SIZE=
UNIFIED_PERF_ALERTS=
UNIFIED_PERF_ALERT_COOLDOWN_MS=
UNIFIED_PERF_ALERT_MIN_SAMPLES=
UNIFIED_PERF_COGNITIVE_LATENCY_CRITICAL_MS=
UNIFIED_PERF_AVG_COST_CRITICAL=
UNIFIED_PERF_TRIAD_USAGE_WARN=
UNIFIED_PERF_LATENCY_IMBALANCE_RATIO=
# Buffer de resumo de influência (taxas agregadas no /unified-health)
UNIFIED_INFLUENCE_SUMMARY_BUFFER=
# Reação interna ao system_influence (ajuste de pipeline/threshold, sem ações externas). false desliga.
UNIFIED_INFLUENCE_REACTIVE=
# Flags legados recommended_system_behavior no meta (influência suave).
UNIFIED_SYSTEM_INFLUENCE=

# -----------------------------------------------------------------------------
# Manutenção / workers / cérebro operacional
# -----------------------------------------------------------------------------
# ManuIA: false ou 0 desativa o router completo; a API responde com JSON controlado (manuiaDisabledFallback).
# Omitir ou true mantém ativo. Requer migração manuia_migration.sql quando usar BD.
ENABLE_MANUIA=
OPERATIONAL_BRAIN_ENABLED=
# Checker a cada 5 min: ativo por omissão quando o cérebro está ligado (como impetus_complete/server.js).
# Defina false ou 0 para desligar apenas o intervalo (OPERATIONAL_BRAIN_CRON_ENABLED=false).
OPERATIONAL_BRAIN_CRON_ENABLED=
REMINDER_SCHEDULER_ENABLED=
OPERATIONAL_MEMORY_ENABLED=
CORPORATE_MEMORY_ENABLED=
LICENSE_SERVER_URL=
LICENSE_API_KEY=
LICENSE_VALIDATION_ENABLED=
LICENSE_KEY=
IMPETUS_LICENSE_KEY=

# -----------------------------------------------------------------------------
# Testes (scripts npm run test:voz, test:realtime, test:did)
# -----------------------------------------------------------------------------
TTS_TEST_ENGINE=impetus
TTS_TEST_VOICE=alloy
TTS_TEST_FRASES=
TTS_TEST_ALT=
REALTIME_TEST_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# PLC / OCR / áudio
# -----------------------------------------------------------------------------
PLC_AI_KEY=
PLC_AI_MODEL=gpt-4o-mini
OCR_ENABLED=
AUDIO_MONITORING_ENABLED=

# -----------------------------------------------------------------------------
# IA proativa / time clock
# -----------------------------------------------------------------------------
AI_PROACTIVE_CONSENT_REQUIRED=
AI_PROACTIVE_BUSINESS_HOURS_ONLY=
AI_PROACTIVE_MAX_PER_USER_PER_DAY=5
TIME_CLOCK_ENC_KEY=

# -----------------------------------------------------------------------------
# ManuIA App (extensão) — Web Push VAPID, inbox, LLM opcional
# Gerar chaves: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
MANUIA_VAPID_PUBLIC_KEY=
MANUIA_VAPID_PRIVATE_KEY=
MANUIA_VAPID_SUBJECT=mailto:suporte@exemplo.com
# Push após ingestão na inbox (só com VAPID e regras de entrega)
MANUIA_WEB_PUSH_ON_INGEST=false
# Inbox ao concluir sessão ManuIA (OS criada)
MANUIA_INBOX_FROM_SESSION=false
# Homologação: POST /app/push/test e POST /app/notifications/simulate-ingest
MANUIA_PUSH_TEST_ENABLED=false
MANUIA_SIMULATE_INGEST_ENABLED=false
# Resumo de notificação com LLM (requer OPENAI_API_KEY)
MANUIA_NOTIFICATION_LLM=false
MANUIA_NOTIFICATION_LLM_MODEL=gpt-4o-mini
MANUIA_NOTIFICATION_LLM_MAX_TOKENS=120
# Smoke: npm run smoke:manuia-app
MANUIA_SMOKE_TOKEN=
MANUIA_SMOKE_URL=
# Motor de despacho (fan-out para equipa de manutenção do tenant)
MANUIA_EVENT_DISPATCH_ENABLED=false
# Após criar linha em plc_alerts (plcDataService), enfileira inbox ManuIA
MANUIA_DISPATCH_PLC=false
# Após INSERT em warehouse_alerts / logistics_alerts / quality_alerts (serviços de inteligência)
MANUIA_DISPATCH_WAREHOUSE=false
MANUIA_DISPATCH_LOGISTICS=false
MANUIA_DISPATCH_QUALITY=false
# Após INSERT em operational_anomalies (recordOperationalAnomaly / futuro motor de deteção)
MANUIA_DISPATCH_OPERATIONAL_ANOMALY=false
# Se o destinatário principal bloquear push (fora de horário) e severidade alta/crítica → supervisores
MANUIA_ESCALATION_ON_BLOCK=false
# POST /app/inbox/:id/escalate — nota aos supervisores
MANUIA_MANUAL_ESCALATION_ENABLED=false

# -----------------------------------------------------------------------------
# Pipeline event-driven (Arquitetura 2.0) e overlay cognitiva
# Camada aditiva — desligada por omissão. Quando IMPETUS_EVENT_PIPELINE_ENABLED=true,
# a sonda em routes/dashboard.js produz um snapshot { intent, summary, entities,
# confidence } via cognitive/cognitiveAttachment.js e enriquece o prompt do
# Cognitive Council. Ver backend/src/eventPipeline/README.md.
# -----------------------------------------------------------------------------
IMPETUS_EVENT_PIPELINE_ENABLED=false
IMPETUS_EVENT_BUS_ADAPTER=in_memory
IMPETUS_EVENT_BUS_LOW_INTERVAL_MS=1500
IMPETUS_SYSTEM_HEALTH_ENABLED=false
# Se definido, audit (event=EVENT_AUDIT) também grava em PostgreSQL nesta tabela.
# A tabela NÃO é criada por este módulo — usar o sistema de migrations existente.
IMPETUS_EVENT_AUDIT_DB_TABLE=
# Debug verboso da overlay cognitiva: emite [COGNITIVE_DEBUG] (NDJSON, com execMs).
# Quando false (default), nenhum custo (Date.now() não é invocado).
IMPETUS_COGNITIVE_DEBUG=false
# Sensor HTTP no Cognitive Controller (processor+Gemini) antes do conselho — não substitui decisão.
IMPETUS_PIPELINE_HTTP_SENSOR=true
# NDJSON [DECISION_CONFLICT] quando heurística do controller ≠ intent do pipeline.
IMPETUS_PIPELINE_CONFLICT_LOG=false
# Governação futura: exige confiança ≥0.7 e sem conflito (observabilidade em councilOptions._pipelineGovernance).
IMPETUS_PIPELINE_GOVERNOR=false
# Se true, handlers do bus chamam OpenAI/Claude em tarefas pipeline (custo + risco; default false).
IMPETUS_PIPELINE_LIVE_CHATGPT=false
IMPETUS_PIPELINE_LIVE_CLAUDE=false
