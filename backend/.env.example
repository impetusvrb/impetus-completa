# =============================================================================
# IMPETUS BACKEND (raiz) — exemplo de variáveis de ambiente
# Copie para .env e preencha. Não commite o ficheiro .env com segredos.
# Unificado com impetus_complete/backend: D-ID, OpenAI Realtime, Google TTS, sockets.
# =============================================================================

NODE_ENV=development
PORT=4000

# -----------------------------------------------------------------------------
# Base de dados PostgreSQL
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=impetus_db
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECT_TIMEOUT=10000

# -----------------------------------------------------------------------------
# JWT e URLs
# -----------------------------------------------------------------------------
JWT_SECRET=
FRONTEND_URL=
BASE_URL=

# -----------------------------------------------------------------------------
# OpenAI (chat, embeddings, Whisper, TTS, Realtime)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova
OPENAI_TTS_DEFAULT_SPEED=0.98
OPENAI_TTS_INSTRUCTIONS=
FORCE_TTS_VOICE=
# Humanização OpenAI TTS (opcional)
OPENAI_TTS_HUMANIZE_STRENGTH=0.65
OPENAI_TTS_WARMTH=0.52
OPENAI_TTS_INTONATION=0.72
OPENAI_TTS_KEYWORD_EMPHASIS=0.72
OPENAI_TTS_SYLLABIC_VARIATION=0.68
OPENAI_TTS_FINAL_FALL=0.74

# Motor TTS: openai | google (via voiceTtsService)
IMPETUS_TTS_PROVIDER=
TTS_ENGINE=
GOOGLE_TTS_ENABLED=

# -----------------------------------------------------------------------------
# OpenAI Realtime (WebSocket proxy no servidor — voz contínua)
# -----------------------------------------------------------------------------
IMPETUS_REALTIME_PROXY_ENABLED=false
IMPETUS_REALTIME_WS_PATH=/impetus-realtime
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# Cabeçalho beta da API OpenAI Realtime (opcional; deixe vazio na maioria dos casos)
OPENAI_REALTIME_BETA=

# -----------------------------------------------------------------------------
# Lipsync Wav2Lip (áudio Realtime → serviço externo)
# -----------------------------------------------------------------------------
IMPETUS_REALTIME_LIPSYNC_ENABLED=false
IMPETUS_LIPSYNC_URL=http://127.0.0.1:5001/lipsync
IMPETUS_LIPSYNC_FACE_VIDEO=
IMPETUS_REALTIME_OUTPUT_AUDIO_HZ=24000
IMPETUS_LIPSYNC_MIN_PCM_BYTES=24000

# -----------------------------------------------------------------------------
# D-ID (avatar talking-head — usado quando rota /api/did estiver montada)
# -----------------------------------------------------------------------------
D_ID_API_KEY=
D_ID_API_BASE=https://api.d-id.com
# URL HTTPS pública da imagem do rosto (teste: scripts/test-did.js)
D_ID_SOURCE_URL=
# No frontend, VITE_DID_SOURCE_URL / VITE_DID_AVATAR_ENABLED alinham com este módulo

# -----------------------------------------------------------------------------
# Socket.IO — namespaces usados no legado impetus_complete (config no código)
# -----------------------------------------------------------------------------
# Chat: /socket.io | Avatar lipsync: /impetus-avatar | TTS stream: /impetus-voice
# CORS e path são definidos em server.js; não há variáveis obrigatórias adicionais hoje.

# -----------------------------------------------------------------------------
# Google Cloud Text-to-Speech
# -----------------------------------------------------------------------------
# Caminho para JSON de service account OU use GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_TTS_KEYFILE=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_LANG=pt-BR
GOOGLE_TTS_VOICE=
GOOGLE_TTS_ENABLED=
GOOGLE_TTS_DEFAULT_SPEAKING_RATE=0.95
GOOGLE_TTS_PITCH=-0.5
GOOGLE_TTS_VOLUME_GAIN_DB=1.5
GOOGLE_TTS_USE_SSML=
GOOGLE_TTS_TEMPLATE_NAME=
GOOGLE_TTS_WELCOME_SPELL_NAME=
# SSML fino (ver googleTtsCore / voiceTtsService)
# Pitch SSML em semitons (opcional; senão usa GOOGLE_TTS_PITCH)
GOOGLE_TTS_SSML_PITCH_ST=
GOOGLE_TTS_SSML_BASE_PITCH_PCT=-1
GOOGLE_TTS_SSML_BASE_RATE_PCT=98
GOOGLE_TTS_SSML_FALL_PITCH_PCT=-2
GOOGLE_TTS_SSML_FALL_RATE_PCT=93
GOOGLE_TTS_SSML_EMPHASIS=moderate
GOOGLE_TTS_SSML_SENTENCE_FALL=
GOOGLE_TTS_SSML_BREATH=
GOOGLE_TTS_SSML_BREATH_MAX=2
GOOGLE_TTS_SSML_OUTER_MODE=pct
GOOGLE_TTS_SSML_NEURAL_OUTER=
GOOGLE_TTS_SSML_NEURAL_OUTER_PITCH_ST=-8
GOOGLE_TTS_SSML_NEURAL_OUTER_RATE_PCT=-17
GOOGLE_TTS_SSML_NEURAL_OUTER_VOLUME=
GOOGLE_TTS_SSML_CHUNK_CLOSURE_MS=
GOOGLE_TTS_SSML_RHYTHM_ALT=
GOOGLE_TTS_SSML_RHYTHM_ALT_RATE_PCT=+6
GOOGLE_TTS_SSML_FINAL_SLOW=
GOOGLE_TTS_SSML_FINAL_SLOW_RATE_PCT=-5
GOOGLE_TTS_BREAK_MS=
GOOGLE_TTS_SENTENCE_BREAK_MS=
GOOGLE_TTS_INTENT_PREFIX=

# -----------------------------------------------------------------------------
# Outras IAs
# -----------------------------------------------------------------------------
# Anthropic: obrigatório para POST /api/vision (ManuIA 3D — Claude multimodal).
# O browser chama /api/vision com o mesmo Bearer do login (impetus_token).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# -----------------------------------------------------------------------------
# Asaas (assinaturas e webhooks)
# -----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=

# -----------------------------------------------------------------------------
# SMTP / e-mail
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_PASSWORD=
SMTP_FROM=

# -----------------------------------------------------------------------------
# Segurança, limites, feature flags
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
SALT=
RATE_LIMIT_API_PER_MIN=120
RATE_LIMIT_USER_PER_MIN=300
RATE_LIMIT_HEAVY_PER_MIN=30
RATE_LIMIT_APP_IMPETUS_PER_SEC=2
PAGINATION_COUNT_CAP=10001
APP_COMM_MAX_FILE_MB=25
CACHE_MAX_ENTRIES=1000
HTTP_TIMEOUT_MS=15000
HTTP_RETRIES=3
LOG_FORMAT=
DEBUG=

FEATURE_AI_CHAT=
FEATURE_OPERATIONAL_BRAIN=
FEATURE_INDUSTRIAL=
FEATURE_ROLE_VERIFICATION=
# Orquestrador multi-modelo no chat/dashboard (legado impetus_complete — chatAIService, rotas dashboard)
AI_ORCHESTRATOR_ENABLED=

# -----------------------------------------------------------------------------
# Manutenção / workers / cérebro operacional
# -----------------------------------------------------------------------------
# ManuIA: false ou 0 desliga /api/manutencao-ia (pesquisa equipamento, máquinas, sessões).
# Omitir ou true mantém ativo. Requer migração manuia_migration.sql quando usar BD.
ENABLE_MANUIA=
OPERATIONAL_BRAIN_ENABLED=
# Checker a cada 5 min: ativo por omissão quando o cérebro está ligado (como impetus_complete/server.js).
# Defina false ou 0 para desligar apenas o intervalo (OPERATIONAL_BRAIN_CRON_ENABLED=false).
OPERATIONAL_BRAIN_CRON_ENABLED=
REMINDER_SCHEDULER_ENABLED=
OPERATIONAL_MEMORY_ENABLED=
CORPORATE_MEMORY_ENABLED=
LICENSE_SERVER_URL=
LICENSE_API_KEY=
LICENSE_VALIDATION_ENABLED=
LICENSE_KEY=
IMPETUS_LICENSE_KEY=

# -----------------------------------------------------------------------------
# Testes (scripts npm run test:voz, test:realtime, test:did)
# -----------------------------------------------------------------------------
TTS_TEST_ENGINE=impetus
TTS_TEST_VOICE=alloy
TTS_TEST_FRASES=
TTS_TEST_ALT=
REALTIME_TEST_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# PLC / OCR / áudio
# -----------------------------------------------------------------------------
PLC_AI_KEY=
PLC_AI_MODEL=gpt-4o-mini
OCR_ENABLED=
AUDIO_MONITORING_ENABLED=

# -----------------------------------------------------------------------------
# IA proativa / time clock
# -----------------------------------------------------------------------------
AI_PROACTIVE_CONSENT_REQUIRED=
AI_PROACTIVE_BUSINESS_HOURS_ONLY=
AI_PROACTIVE_MAX_PER_USER_PER_DAY=5
TIME_CLOCK_ENC_KEY=
