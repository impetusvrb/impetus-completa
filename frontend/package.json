{
  "name": "impetus-comunica-ia-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:atomic": "node scripts/atomic-deploy-build.cjs",
    "preview": "vite preview",
    "preview:prod": "node serveDist.cjs",
    "serve:dist": "node serveDist.cjs",
    "serve:static": "node server.cjs",
    "security:audit": "npm audit --production",
    "security:audit:ci": "npm audit --production --audit-level=high",
