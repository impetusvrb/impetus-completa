    "test:enterprise:chunks": "node src/tests/enterprise/chunkLoadingStress.cjs",
    "test:enterprise:realtime": "node src/tests/enterprise/realtimeReconnectStress.cjs",
    "test:enterprise:offline": "node src/tests/enterprise/offlineQueueStress.cjs",
    "test:enterprise:workflow": "node src/tests/enterprise/workflowRenderingStress.cjs",
    "test:enterprise-soak": "node src/tests/enterprise/chunkLoadingStress.cjs && node src/tests/enterprise/realtimeReconnectStress.cjs && node src/tests/enterprise/offlineQueueStress.cjs && node src/tests/enterprise/workflowRenderingStress.cjs",
    "test:quality-operational-runtime": "node src/tests/quality-operational-runtime/qualityOperationalFrontendScenarios.mjs",
    "test:quality-enterprise-runtime": "node src/tests/quality-enterprise-runtime/qualityEnterpriseRuntimeScenarios.mjs",
    "test:quality-governance-runtime": "node src/tests/quality-governance-runtime/qualityGovernanceRuntimeScenarios.mjs",
    "test:quality-cognitive-runtime": "node src/tests/quality-cognitive-runtime/qualityCognitiveRuntimeScenarios.mjs",
    "test:quality-rollout-runtime": "node src/tests/quality-rollout-runtime/qualityRolloutRuntimeScenarios.mjs",
    "test:quality-publication-runtime": "node src/tests/quality-publication-runtime/qualityPublicationMenuScenarios.mjs",
    "test:quality-publication-activation": "node --experimental-vm-modules src/tests/quality-publication-activation/qualityPublicationActivationScenarios.mjs",
    "test:quality-navigation-stabilization": "node --experimental-vm-modules src/tests/quality-navigation-stabilization/qualityNavigationStabilizationScenarios.mjs",
    "test:enterprise-runtime-stability": "node --experimental-vm-modules src/tests/runtime-stability/enterpriseRuntimeStabilityScenarios.mjs",
    "test:safety-publication-runtime": "node --experimental-vm-modules src/tests/safety-publication-runtime/safetyPublicationRuntimeScenarios.mjs",
    "test:safety-operational-validation": "node --experimental-vm-modules src/tests/safety-operational-validation/safetyOperationalValidationScenarios.mjs",
    "test:enterprise-runtime-validation": "node --experimental-vm-modules src/tests/enterprise-runtime-validation/enterpriseRuntimeValidationScenarios.mjs",
    "test:logistics-runtime-validation": "node --experimental-vm-modules src/tests/logistics-runtime-validation/logisticsRuntimeValidationScenarios.mjs"
