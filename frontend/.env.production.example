# Impetus Comunica IA - Frontend Produção
# Copie para .env.production antes do build (ou use ARG no Docker)
# O Dockerfile.prod já usa VITE_API_URL=/api por padrão

VITE_API_URL=/api

# Avatar /app/chatbot: usar MP4 em /videos/ (activation/speaking/idle-*), igual ao avatar-impetus.html — precisa de build após ativar.
# VITE_AVATAR_NINE_VIDEOS=true

# Modo voz OpenAI Realtime (conversa contínua via ws /impetus-realtime). No backend: IMPETUS_REALTIME_PROXY_ENABLED=true
# Padrão no vite.config.js é true; use false para voltar ao STT+TTS clássico.
# VITE_VOICE_REALTIME=false
# Modo reunião: respostas mais curtas, VAD mais paciente, margens maiores após a fala da IA.
# VITE_REALTIME_MEETING=true
# VITE_REALTIME_INSTRUCTIONS=
# VITE_REALTIME_WS_PATH=/impetus-realtime

# Dashboard Inteligente Dinâmico (spec v3). Use false para desativar e rollback.
VITE_ENABLE_DYNAMIC_DASHBOARD=true
