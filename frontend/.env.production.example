# Impetus Comunica IA - Frontend Produção
# Copie para .env.production antes do build (ou use ARG no Docker)
# O Dockerfile.prod já usa VITE_API_URL=/api por padrão.
# Em servidor próprio: use /api e sirva o dist com `npm run preview:prod` (proxy no vite.config)
# ou nginx na mesma origem — nunca aponte o browser direto para :4000 se usar HTTPS ou firewall.

VITE_API_URL=/api

# Avatar /app/chatbot: usar MP4 em /videos/ (activation/speaking/idle-*), igual ao avatar-impetus.html — precisa de build após ativar.
# VITE_AVATAR_NINE_VIDEOS=true

# Vídeo principal de fala (close-up realista): copie o MP4 para frontend/public/videos/ (ex.: hero-speaking.mp4) e ative:
# VITE_AVATAR_HERO_SPEAKING_VIDEO=true
# Opcional — URL/path servido em public/ (padrão /videos/hero-speaking.mp4):
# VITE_AVATAR_HERO_SPEAKING_SRC=/videos/hero-speaking.mp4

# Modo ouvir / analisar (transição suave com os clipes idle em 9 vídeos)
# VITE_AVATAR_LISTEN_VIDEO=/videos/listening-blink.mp4
# VITE_AVATAR_ANALYZE_VIDEO=/videos/analyzing-assistant.mp4

# D-ID no modo voz: vídeo talking-head via backend (/api/did). A D-ID anima uma imagem estática (face).
# VITE_DID_AVATAR_ENABLED=true
# Opcional: URL HTTPS pública da imagem. Se vazio, usa https://<teu-site>/impetus-did-source.jpg (public/impetus-did-source.jpg).
# VITE_DID_SOURCE_URL=https://teu-dominio.com/impetus-did-source.jpg

# Modo voz OpenAI Realtime (conversa contínua via ws /impetus-realtime). No backend: IMPETUS_REALTIME_PROXY_ENABLED=true
# Padrão no vite.config.js é true; use false para voltar ao STT+TTS clássico.
# VITE_VOICE_REALTIME=false
# Modo reunião: respostas mais curtas, VAD mais paciente, margens maiores após a fala da IA.
# VITE_REALTIME_MEETING=true
# VITE_REALTIME_INSTRUCTIONS=
# VITE_REALTIME_WS_PATH=/impetus-realtime

# Dashboard Inteligente Dinâmico (spec v3). Use false para desativar e rollback.
VITE_ENABLE_DYNAMIC_DASHBOARD=true
