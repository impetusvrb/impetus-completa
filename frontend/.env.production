# Mesma origem que a página: o servidor (vite preview ou nginx) faz proxy de /api → backend :4000.
# Evita conteúdo misto (HTTPS→HTTP), CORS e firewall bloqueando a porta 4000 no cliente.
VITE_API_URL=/api
VITE_AVATAR_NINE_VIDEOS=true
VITE_AVATAR_HERO_SPEAKING_VIDEO=true
VITE_AVATAR_HERO_SPEAKING_SRC=/videos/hero-speaking.mp4

# Ouvindo o utilizador / analisando (coloque os MP4 em public/videos/ com estes nomes)
VITE_AVATAR_LISTEN_VIDEO=/videos/listening-blink.mp4
VITE_AVATAR_ANALYZE_VIDEO=/videos/analyzing-assistant.mp4

# Avatar 3D no overlay de voz: coloque o .glb em public/ com o mesmo nome (sem espaços).
VITE_VOICE_AVATAR_3D_GLB=off
VITE_VOICE_AVATAR_3D_FIT=1.35
VITE_VOICE_AVATAR_3D_OFFSET_Y=-0.58
VITE_VOICE_AVATAR_3D_ROTATE_Y_DEG=0
VITE_VOICE_AVATAR_3D_ROTATE_X_DEG=0

# D-ID: backend precisa de D_ID_API_KEY; imagem abaixo tem de ser HTTPS pública (mesmo domínio ou CDN).
VITE_DID_AVATAR_ENABLED=true
# Obrigatório para o vídeo gerado aparecer — substitua pela URL real do PNG/JPG do avatar:
VITE_DID_SOURCE_URL=http://72.61.221.152:3000/impetus-did-source.jpg

# ─── QUALITY publication activation (controlled deploy) ───
VITE_IMPETUS_QUALITY_NAVIGATION_ENABLED=true
VITE_IMPETUS_QUALITY_PUBLICATION_RUNTIME_ENABLED=true
VITE_IMPETUS_QUALITY_OPERATIONAL_VISIBILITY_ENABLED=true
VITE_IMPETUS_QUALITY_GOVERNANCE_VISIBILITY_ENABLED=true
VITE_IMPETUS_QUALITY_EXECUTIVE_VISIBILITY_ENABLED=true
# Runtimes QUALITY (obrigatório para Inspeções, NCR, Telemetria, Inteligência contextual)
VITE_IMPETUS_QUALITY_OPERATIONAL_RUNTIME_ENABLED=true
VITE_IMPETUS_QUALITY_OPERATIONAL_DIAGNOSTICS=true
VITE_IMPETUS_QUALITY_OFFLINE_RUNTIME_ENABLED=true
VITE_IMPETUS_QUALITY_GOVERNANCE_RUNTIME_ENABLED=true
VITE_IMPETUS_QUALITY_TELEMETRY_RUNTIME_ENABLED=true
VITE_IMPETUS_QUALITY_COGNITIVE_RUNTIME_ENABLED=true
VITE_IMPETUS_QUALITY_ROLLOUT_RUNTIME_ENABLED=true
