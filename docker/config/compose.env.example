# Variáveis Docker Compose (raiz do repositório)
# CERT-ONPREM-CONTAINER-01
#
# Copiar para .env na raiz:
#   cp docker/config/compose.env.example .env
#
# Configuração da aplicação: ${IMPETUS_HOME}/config/.env (fonte única certificada)

IMPETUS_HOME=/opt/impetus
POSTGRES_USER=impetus_app
POSTGRES_PASSWORD=ALTERAR_SENHA_FORTE
POSTGRES_DB=impetus_db
IMPETUS_HTTP_PORT=80
IMPETUS_HTTPS_PORT=443
IMPETUS_IMAGE_TAG=latest
VITE_API_URL=/api
