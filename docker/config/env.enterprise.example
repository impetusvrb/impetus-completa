# IMPETUS Enterprise — template de configuração Docker
# CERT-ONPREM-CONTAINER-01
#
# Copiar para ${IMPETUS_HOME}/config/.env — FONTE ÚNICA certificada (INFRA-01 / DATA-01)
# Nunca commitar .env com segredos reais.

# --- Layout ---
IMPETUS_HOME=/opt/impetus

# --- Runtime backend (PM2 inalterado; env para rede Docker) ---
NODE_ENV=production
PORT=4000
# Rede Docker interna: nginx → backend via hostname (NC-CONTAINER-01 — ver matriz)
LISTEN_HOST=0.0.0.0
ALLOW_PUBLIC_BIND=true

# --- Runtime frontend (PM2 preview:prod) ---
SERVE_DIST_HOST=0.0.0.0
SERVE_DIST_PORT=3000
API_PROXY_TARGET=http://backend:4000

# --- URLs públicas (domínio da fábrica) ---
FRONTEND_URL=http://localhost
ALLOWED_ORIGINS=http://localhost
BASE_URL=http://localhost

# --- PostgreSQL (compose: host=postgres) ---
DATABASE_URL=postgresql://impetus_app:ALTERAR_SENHA@postgres:5432/impetus_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=impetus_db
DB_USER=impetus_app
DB_PASSWORD=ALTERAR_SENHA

# --- Segurança ---
JWT_SECRET=GERAR_STRING_ALEATORIA_MIN_32_CHARS

# --- Bootstrap (1ª instalação BD vazia; omitir em upgrades) ---
ENTERPRISE_BOOTSTRAP_ADMIN_EMAIL=admin@fabrica.local
ENTERPRISE_BOOTSTRAP_ADMIN_PASSWORD=AlterarSenhaForte1
ENTERPRISE_BOOTSTRAP_COMPANY_NAME=Fábrica Enterprise

# --- Licenciamento (CERT-LICENSE-01) ---
LICENSE_VALIDATION_ENABLED=false
LICENSE_MODE=local
LICENSE_GRACE_PERIOD_DAYS=14
# LICENSE_PUBLIC_KEY_PATH=/opt/impetus/licenses/public.pem

# --- SaaS desactivado (Enterprise) ---
ENABLE_NEXUS_TOKEN_BILLING_CRON=false
ENABLE_SUBSCRIPTION_GOVERNANCE_CRON=false

# --- IA cloud opcional (egress permitido) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# ANAM_API_KEY=

# --- Event Backbone conservador ---
IMPETUS_INDUSTRIAL_BACKBONE_MODE=shadow
IMPETUS_EVENT_RETENTION_MODE=shadow
IMPETUS_COGNITIVE_LIVING_ENRICHMENT=false
IMPETUS_INDUSTRIAL_LAB_ENABLED=false

# --- Frontend build (compose build-arg; runtime usa /api relativo) ---
VITE_API_URL=/api

# --- PM2 container (runtime oficial) ---
PM2_HOME=/opt/impetus/runtime/pm2-backend
