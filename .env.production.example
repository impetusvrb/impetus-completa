# ============================================================================
# IMPETUS COMUNICA IA - PRODUÇÃO
# ============================================================================
# Copie para .env ao implantar em servidor industrial
# ============================================================================

NODE_ENV=production
PORT=4000
FRONTEND_URL=https://seu-dominio.com

DB_HOST=localhost
DB_PORT=5432
DB_NAME=impetus_db
DB_USER=impetus_app
DB_PASSWORD=senha_forte_aqui

# Pool maior para carga
DB_POOL_MAX=20

# Retenção de logs (dias) - manutenção
AUDIT_LOG_RETENTION_DAYS=90

CACHE_MAX_ENTRIES=2000
HTTP_TIMEOUT_MS=20000
HTTP_RETRIES=3

# Health check
BASE_URL=http://localhost:4000

# Motor unificado — validação comportamental (default OFF em produção até validação explícita)
# UNIFIED_STABILITY_MONITOR=false
# UNIFIED_LEARNING_INTEGRITY=false
# UNIFIED_CONSERVATISM_GUARD=false
# UNIFIED_METRICS_INTERPRETER=false
# UNIFIED_BEHAVIOR_DRIFT=false
# UNIFIED_BEHAVIOR_GUARD=false
# Fachada única de decisão (ON: dashboard /chat encaminha ao motor via decisionFacadeService)
# USE_DECISION_FACADE=false
# Validação de coerência facade vs motor (staging; logs [DECISION_FACADE_COHERENCE])
# DECISION_FACADE_VALIDATE=false

# Licenciamento - Em produção, configure para validar
LICENSE_VALIDATION_ENABLED=true
LICENSE_SERVER_URL=https://licenca.impetus.com.br/api/validate
LICENSE_KEY=sua_chave_de_licenca
LICENSE_API_KEY=sua_api_key_licencas
